# Bid.Fast Environment Variables
# Copy this file to .env.local and fill in your values. Never commit .env.local.

# App
NEXT_PUBLIC_APP_NAME=Bid.Fast
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Project Settings → API Keys (Legacy section)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq — handles both Whisper transcription and LLaMA 3.3 70B estimate generation
GROQ_API_KEY=your-groq-api-key

# Optional — Email delivery via Resend (client estimate emails)
# RESEND_API_KEY=your-resend-api-key

# Bid.Fast Environment Variables

# App
NEXT_PUBLIC_APP_NAME=Bid.Fast
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI — Transcription (Groq Whisper)
GROQ_API_KEY=your-groq-api-key

# AI — Estimate Generation (Gemini Flash)
# NOTE: The build prompt requests Anthropic/Claude for estimate generation.
# Anthropic SDK is not in package.json, so Gemini is used instead.
# To use Claude: install @anthropic-ai/sdk, add ANTHROPIC_API_KEY, and swap the provider in app/api/estimates/generate/route.ts
GEMINI_API_KEY=your-gemini-api-key

# Optional — Email (Resend)
# RESEND_API_KEY=your-resend-api-key
